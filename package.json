{
  "name": "nerdhaven",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postbuild": "test -d .next/standalone/nerdhaven && cp -r public/. .next/standalone/nerdhaven/public/ && rm -f .next/standalone/nerdhaven/.env || true",
    "start": "node .next/standalone/nerdhaven/server.js",
    "lint": "eslint",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-resources": "tsx prisma/seed-actual-resources.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "vercel-build": "prisma generate && next build"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sendgrid/mail": "^8.1.6",
    "@tanstack/react-query": "^5.101.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "pdfkit": "^0.19.1",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
